# Local dev only — set these in Netlify dashboard for production.

# Alpaca — market data (required)
# Get keys at https://alpaca.markets/ (Paper trading account is fine for data access)
APCA_API_KEY_ID=your_alpaca_key_here
APCA_API_SECRET_KEY=your_alpaca_secret_here
ALPACA_FEED=iex

# Financial Modeling Prep — real PE, FCF yield, EPS (optional but recommended)
# Free tier: 250 calls/day. Get key at https://financialmodelingprep.com/developer/docs
# Without this, Fair Value falls back to a 5% FCF yield proxy (less accurate).
FMP_API_KEY=your_fmp_key_here
